# DistributedLab Environment Configuration
# Copy to .env and adjust as needed

# Service Ports
CONTROL_PANEL_PORT=3000
LAB_API_PORT=3001
MONOLITH_PORT=8080
CATALOG_SERVICE_PORT=8081
ORDER_SERVICE_PORT=8082
PAYMENT_SERVICE_PORT=8083
ENVOY_PORT=8000

# Infrastructure Ports
KAFKA_PORT=9092
POSTGRES_PORT=5432
MONGODB_PORT=27017
REDIS_PORT=6379
NEO4J_PORT=7687
ELASTICSEARCH_PORT=9200

# Observability Ports
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
JAEGER_PORT=16686
LOKI_PORT=3100

# Resource Limits (MB)
LAB_API_MEMORY=1024
MONOLITH_MEMORY=1024
CATALOG_MEMORY=512
ORDER_MEMORY=512
PAYMENT_MEMORY=512
CONTROL_PANEL_MEMORY=512
